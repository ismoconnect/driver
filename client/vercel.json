{
  "rewrites": [
    {
      "source": "/((?!api/.*).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|twitterbot|linkedinbot|embedly|quora|pinterest|slackbot|vkShare|whatsapp|opengraph|google|bot|fetch|axios|node|preview).*"
        }
      ],
      "destination": "/api/og"
    },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ]
}

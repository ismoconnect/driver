rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Vérifie si l'utilisateur connecté est un administrateur agréé
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: Vérifie si l'utilisateur connecté est un super administrateur
    function isSuperAdmin() {
      return isAdmin() && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super_admin';
    }

    // ── Collection "users" ──────────────────────────────────────────────────
    // Créée à l'inscription. Chaque utilisateur lit/écrit son profil, les admins peuvent tout lire/écrire.
    match /users/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // ── Collection "leads" ──────────────────────────────────────────────────
    // Dossier permis de conduire. Accessible par le propriétaire et par les administrateurs.
    match /leads/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // ── Sous-collection messages ─────────────────────────────────────────────
    match /leads/{userId}/messages/{messageId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }

    // ── Collection "settings" ────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Collection "marketing" ───────────────────────────────────────────────
    match /marketing/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Collection "chats" ────────────────────────────────────────────────────
    match /chats/{userId} {
      allow read, write: if (request.auth != null && request.auth.uid == userId) || isAdmin();
    }
    match /chats/{userId}/messages/{messageId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow create: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow update: if false;
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId && resource.data.sender == 'student');
    }

    // ── Collection "admins" ──────────────────────────────────────────────────
    // Lecture et écriture autorisées pour les administrateurs
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // ── Collection "aibv_emails_logs" ────────────────────────────────────────
    // Lecture et écriture autorisées pour les administrateurs pour l'historique d'envoi
    match /aibv_emails_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Bloquer tout le reste par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
